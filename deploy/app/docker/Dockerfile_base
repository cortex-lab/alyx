FROM ubuntu/apache2:2.4-25.04_beta

# python unbuffered allows to get real-time logs
ENV PYTHONUNBUFFERED=1
ARG TZ=UTC
ENV TZ=${TZ}
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

RUN cat /etc/lsb-release && apt-get update
# Install services, packages and perform cleanup
RUN apt-get install -y \
    awscli \
    bash \
    build-essential \
    certbot \
    gcc \
    git \
    libapache2-mod-wsgi-py3 \
    libpq-dev \
    python3-certbot-apache \
    vim \
    w3m \
    wget

# Python 3.13 is the system Python on Ubuntu 25.04, so libapache2-mod-wsgi-py3 (built against
# it) matches the venv below — no PPA needed and no mod_wsgi/venv version skew.
ARG PYTHON=python3.13
RUN apt-get install -y ${PYTHON} ${PYTHON}-venv

# uv for fast, reproducible dependency management (used for the venv + installs below)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Clean up
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

RUN echo "root:Docker!" | chpasswd

# Alyx application installation
# Note: Alyx is checked out and pip installed again in the head container
# Doing it here makes head container releases very fast as the clone is present and pip cache already built
ARG alyx_branch=dev
RUN git clone --branch ${alyx_branch} https://github.com/cortex-lab/alyx.git /var/www/alyx
# Create the venv with the system Python 3.13 (ABI-matches mod_wsgi) and install deps with uv
ENV VIRTUAL_ENV=/var/www/alyx/.venv
RUN uv venv --python /usr/bin/${PYTHON} ${VIRTUAL_ENV}
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
WORKDIR /var/www/alyx
RUN uv pip install --no-cache -r requirements.txt
RUN uv pip install --no-cache dj-database-url

# Apache ENVs
ENV APACHE_RUN_USER=www-data
ENV APACHE_RUN_GROUP=www-data
ENV APACHE_LOCK_DIR=/var/lock/apache2
ENV APACHE_LOG_DIR=/var/log/apache2
ENV APACHE_PID_FILE=/var/run/apache2/apache2.pid

RUN mkdir -p ${APACHE_LOG_DIR} \
    && touch ${APACHE_LOG_DIR}/django.log \
    && touch ${APACHE_LOG_DIR}/django.json \
    && chown -R ${APACHE_RUN_USER}:${APACHE_RUN_GROUP} ${APACHE_LOG_DIR}

# Apache configs
COPY apache2.conf /etc/apache2/apache2.conf
COPY 000-default.conf /etc/apache2/sites-available/000-default.conf
COPY alyx-common.conf /etc/apache2/sites-available/alyx-common.conf
COPY options-ssl-apache.conf /etc/apache2/sites-available/options-ssl-apache.conf

# Runtime scripts (alyx_issue_ssl.sh is invoked by the deploy compose command at container start)
COPY scripts/ /usr/local/bin/
RUN chmod +x /usr/local/bin/*.sh

# This should be the same as MEDIA_ROOT in settings-deploy.py (c.f. optional env var DJANGO_MEDIA_ROOT)
RUN mkdir /var/www/alyx/alyx/uploaded
RUN chown www-data:www-data -fR /var/www/alyx/alyx/uploaded

RUN a2enmod rewrite
RUN a2enmod ssl
RUN a2enmod wsgi
